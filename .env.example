# =============================================================================
# NOUREDDINE Data Platform — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=noureddine
POSTGRES_USER=noureddine_user
POSTGRES_PASSWORD=change_me_postgres

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@noureddine.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin
PGADMIN_PORT=5050

# --- MinIO ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Airflow ---
AIRFLOW_PORT=8080
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow
AIRFLOW_ADMIN_EMAIL=admin@noureddine.com

# --- Grafana (Bloc 3) ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# --- Simulator (Bloc 3) ---
SIM_MODE=history
DRIP_INTERVAL_SECONDS=10
SIM_N_CUSTOMERS=15000
SIM_N_PRODUCTS=300
SIM_N_ORDERS=20000

# --- Alerting (Bloc 3) ---
# ALERT_WEBHOOK_URL=https://hooks.example.com/your-webhook
# FORCE_FAILURE=0
