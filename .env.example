# =============================================================================
# NOUREDDINE Data Platform — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=noureddine
POSTGRES_USER=noureddine_user
POSTGRES_PASSWORD=change_me_postgres

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@noureddine.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin
PGADMIN_PORT=5050

# --- MinIO ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Simulator (Bloc 3) ---
CATCH_UP_INTERVAL_SECONDS=600   # seconds between catch-up cycles (0 in CI/demos to run once)

# --- Airflow ---
AIRFLOW_PORT=8080
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow
AIRFLOW_ADMIN_EMAIL=admin@noureddine.com

# --- Bloc 4: FastAPI serving ---
API_PORT=8000
API_KEY=change_me_api_key            # required in X-API-Key header on /predict and /retrain
API_URL=http://api:8000              # used by Streamlit to reach the API

# --- Bloc 4: Streamlit business app ---
STREAMLIT_PORT=8501
STOCK_RED_DAYS=7                     # days-of-cover < this -> 🔴 reorder now
STOCK_ORANGE_DAYS=14                 # days-of-cover < this -> 🟠 watch
RESTOCK_LEAD_TIME_DAYS=21            # AI Advisor: délai de réappro (rupture si couverture < ce délai)

# --- Bloc 4: model monitoring (Evidently -> retrain triggers) ---
DRIFT_THRESHOLD=0.5                  # breach if share of drifted features >= this
MAPE_THRESHOLD=0.30                  # breach if current MAPE >= this
FORCE_DRIFT=0                        # set 1 to force a drift breach (demo)

# --- Bloc 4: Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# --- Bloc 4: optional LLM Stock Advisor (Streamlit page 4, ADR 0015) ---
# Leave empty to keep the zero-licence baseline (the page degrades gracefully).
# Works with any OpenAI-compatible provider via OPENAI_BASE_URL:
#   OpenAI   -> base empty,                  model gpt-4o-mini
#   DeepSeek -> https://api.deepseek.com,    model deepseek-chat
#   xAI Grok -> https://api.x.ai/v1,         model grok-2-latest
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
