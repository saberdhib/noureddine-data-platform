      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.2 },
            { "color": "red", "value": 0.3 }
          ] }
        }, "overrides": []
