      "targets": [ {
        "refId": "A", "format": "time_series", "rawQuery": true,
        "datasource": { "type": "postgres", "uid": "noureddine_pg" },
        "rawSql": "SELECT measured_at AS time, drift_score AS \"Drift score\" FROM monitoring.model_metrics WHERE $__timeFilter(measured_at) ORDER BY measured_at;"
      } ]
    },
    {
      "type": "table",
      "title": "Retraining events (promote / no-promote)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
