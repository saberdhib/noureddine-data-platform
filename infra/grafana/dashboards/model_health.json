      "targets": [ {
        "refId": "A", "format": "table", "rawQuery": true,
        "datasource": { "type": "postgres", "uid": "noureddine_pg" },
        "rawSql": "SELECT mape AS value FROM monitoring.model_metrics ORDER BY measured_at DESC LIMIT 1;"
      } ]
