      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [ {
        "refId": "A", "format": "table", "rawQuery": true,
        "datasource": { "type": "postgres", "uid": "noureddine_pg" },
        "rawSql": "SELECT occurred_at AS \"time\", model_version, current_mape, new_mape, promoted, reason FROM monitoring.retrain_events ORDER BY occurred_at DESC LIMIT 50;"
